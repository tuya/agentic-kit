	branch = main
[submodule "third_party/cJSON"]
	path = third_party/cJSON
	url = https://github.com/DaveGamble/cJSON.git
[submodule "third_party/coreMQTT"]
	path = third_party/coreMQTT
	url = https://github.com/FreeRTOS/coreMQTT.git
	branch = main

