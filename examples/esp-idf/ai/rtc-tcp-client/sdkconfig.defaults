CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
CONFIG_LWIP_SO_RCVTIMEO=y
CONFIG_LWIP_SO_SNDTIMEO=y
CONFIG_FREERTOS_USE_RECURSIVE_MUTEXES=y
